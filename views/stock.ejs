<%- include('layout') %>

<% if (lowStock.length) { %>
<div class="bg-red-900/30 border border-red-800 rounded-xl p-4 mb-6">
  <h3 class="text-red font-bold flex items-center gap-2 mb-2"><span class="material-symbols-outlined">warning</span> Düşük Stok Uyarısı</h3>
  <div class="flex flex-wrap gap-2">
    <% lowStock.forEach(i => { %>
    <span class="bg-red-900/50 text-red-300 px-3 py-1 rounded-full text-sm"><%= i.product_name %> — <strong><%= i.quantity %></strong> adet</span>
    <% }) %>
  </div>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="bg-surface border border-border rounded-xl p-5">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-red">Stok Listesi</h2>
        <span class="text-muted text-sm"><%= items.length %> ürün</span>
      </div>
      <% if (items.length) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead><tr class="text-muted border-b border-border">
            <th class="py-2 pr-3">Ürün</th><th class="py-2 pr-3">SKU</th><th class="py-2 pr-3 text-center">Stok</th><th class="py-2 pr-3 text-center">Min</th><th class="py-2 pr-3 text-right">Birim Maliyet</th><th class="py-2 text-center">İşlem</th>
          </tr></thead>
          <tbody>
            <% items.forEach(i => { const low = i.quantity <= i.min_quantity; %>
            <tr class="border-b border-border/30 hover:bg-white/5 <%= low ? 'bg-red-900/10' : '' %>">
              <td class="py-3 pr-3 font-bold"><%= i.product_name %><% if (i.category) { %> <span class="text-muted text-xs">(<%= i.category %>)</span><% } %></td>
              <td class="py-3 pr-3 font-mono text-xs text-muted"><%= i.sku || '-' %></td>
              <td class="py-3 pr-3 text-center font-bold <%= low ? 'text-red' : 'text-green-400' %>"><%= i.quantity %></td>
              <td class="py-3 pr-3 text-center text-muted"><%= i.min_quantity %></td>
              <td class="py-3 pr-3 text-right"><%= money(i.unit_cost) %></td>
              <td class="py-3 text-center">
                <div class="flex items-center justify-center gap-1">
                  <button onclick="editStock(<%= i.id %>,'<%- i.product_name.replace(/'/g,"\\'") %>','<%= i.sku||'' %>',<%= i.quantity %>,<%= i.min_quantity %>,<%= i.unit_cost %>,'<%= i.category||'' %>')" class="text-muted hover:text-white p-1"><span class="material-symbols-outlined text-[18px]">edit</span></button>
                  <button onclick="moveStock(<%= i.id %>,'<%- i.product_name.replace(/'/g,"\\'") %>')" class="text-muted hover:text-green-400 p-1"><span class="material-symbols-outlined text-[18px]">swap_vert</span></button>
                  <form method="POST" action="/stok/sil" class="inline" onsubmit="return confirm('Bu stok kaydını silmek istediğinden emin misin?')"><input type="hidden" name="id" value="<%= i.id %>"><button class="text-muted hover:text-red p-1"><span class="material-symbols-outlined text-[18px]">delete</span></button></form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-muted text-center py-8">Henüz stok kaydı yok.</p>
      <% } %>
    </div>
  </div>

  <div class="space-y-6">
    <div class="bg-surface border border-border rounded-xl p-5">
      <h3 class="text-red font-bold mb-4" id="form-title">Yeni Stok Ekle</h3>
      <form method="POST" action="/stok/kaydet" class="space-y-3" id="stock-form">
        <input type="hidden" name="id" id="sf-id" value="">
        <div>
          <label class="text-muted text-sm block mb-1">Ürün Adı *</label>
          <input name="product_name" id="sf-name" required class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Daikin 12000 BTU">
        </div>
        <div>
          <label class="text-muted text-sm block mb-1">SKU / Stok Kodu</label>
          <input name="sku" id="sf-sku" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="HNT-12K">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-muted text-sm block mb-1">Miktar</label>
            <input name="quantity" id="sf-qty" type="number" value="0" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
          <div>
            <label class="text-muted text-sm block mb-1">Minimum Stok</label>
            <input name="min_quantity" id="sf-min" type="number" value="2" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-muted text-sm block mb-1">Birim Maliyet (TL)</label>
            <input name="unit_cost" id="sf-cost" type="number" step="0.01" value="0" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
          <div>
            <label class="text-muted text-sm block mb-1">Kategori</label>
            <input name="category" id="sf-cat" value="Klima" list="cat-list" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Klima / Yedek Parça">
            <datalist id="cat-list">
              <option value="Klima"></option>
              <option value="Yedek Parça"></option>
              <option value="Aksesuar"></option>
              <option value="Sarf Malzeme"></option>
            </datalist>
          </div>
        </div>
        <div class="flex gap-2">
          <button type="submit" class="flex-grow bg-red hover:bg-red-700 text-white font-bold py-3 rounded-lg">Kaydet</button>
          <button type="button" onclick="resetForm()" class="bg-surface border border-border text-muted px-4 py-3 rounded-lg hover:text-white hidden" id="cancel-btn">İptal</button>
        </div>
      </form>
    </div>

    <div class="bg-surface border border-border rounded-xl p-5 hidden" id="move-panel">
      <h3 class="text-red font-bold mb-2">Stok Hareketi</h3>
      <p class="text-muted text-sm mb-4" id="move-name"></p>
      <form method="POST" action="/stok/hareket" class="space-y-3">
        <input type="hidden" name="stock_id" id="mv-id">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-muted text-sm block mb-1">Tür</label>
            <select name="type" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
              <option value="giris">Giriş (+)</option><option value="cikis">Çıkış (−)</option>
            </select>
          </div>
          <div>
            <label class="text-muted text-sm block mb-1">Adet</label>
            <input name="quantity" type="number" min="1" value="1" required class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
        </div>
        <div>
          <label class="text-muted text-sm block mb-1">Not</label>
          <input name="note" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Satış, iade, transfer vb.">
        </div>
        <button class="w-full bg-green-700 hover:bg-green-600 text-white font-bold py-3 rounded-lg">Kaydet</button>
      </form>
    </div>
  </div>
</div>

<% if (movements.length) { %>
<div class="bg-surface border border-border rounded-xl p-5 mt-6">
  <h2 class="text-lg font-bold text-red mb-4 flex items-center gap-2"><span class="material-symbols-outlined">history</span> Son Stok Hareketleri</h2>
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm">
      <thead><tr class="text-muted border-b border-border">
        <th class="py-2 pr-3">Tarih & Saat</th>
        <th class="py-2 pr-3">Ürün</th>
        <th class="py-2 pr-3 text-center">Tür</th>
        <th class="py-2 pr-3 text-center">Adet</th>
        <th class="py-2 pr-3">Yapan</th>
        <th class="py-2">Not</th>
      </tr></thead>
      <tbody>
        <% movements.forEach(m => { %>
        <tr class="border-b border-border/30 hover:bg-white/5">
          <td class="py-2 pr-3 text-muted text-xs whitespace-nowrap"><%= m.created_at %></td>
          <td class="py-2 pr-3 font-bold"><%= m.product_name %></td>
          <td class="py-2 pr-3 text-center">
            <span class="px-2 py-1 rounded-full text-xs font-bold <%= m.type==='giris'?'bg-green-900/50 text-green-400':'bg-red-900/50 text-red-400' %>"><%= m.type==='giris'?'Giriş':'Çıkış' %></span>
          </td>
          <td class="py-2 pr-3 text-center font-bold <%= m.type==='giris'?'text-green-400':'text-red' %>"><%= m.type==='giris'?'+':'-' %><%= m.quantity %></td>
          <td class="py-2 pr-3"><%= m.user_name || '-' %></td>
          <td class="py-2 text-muted"><%= m.note || '-' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<script>
function editStock(id,name,sku,qty,min,cost,cat){
  document.getElementById('sf-id').value=id;
  document.getElementById('sf-name').value=name;
  document.getElementById('sf-sku').value=sku;
  document.getElementById('sf-qty').value=qty;
  document.getElementById('sf-min').value=min;
  document.getElementById('sf-cost').value=cost;
  document.getElementById('sf-cat').value=cat;
  document.getElementById('form-title').textContent='Stok Düzenle';
  document.getElementById('cancel-btn').classList.remove('hidden');
}
function resetForm(){
  document.getElementById('stock-form').reset();
  document.getElementById('sf-id').value='';
  document.getElementById('form-title').textContent='Yeni Stok Ekle';
  document.getElementById('cancel-btn').classList.add('hidden');
}
function moveStock(id,name){
  document.getElementById('mv-id').value=id;
  document.getElementById('move-name').textContent=name;
  document.getElementById('move-panel').classList.remove('hidden');
  document.getElementById('move-panel').scrollIntoView({behavior:'smooth'});
}
</script>

<%- include('layout-end') %>
