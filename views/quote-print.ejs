<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Teklif #<%= quote.id %> — Ram İklimlendirme</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: 'Segoe UI', Tahoma, sans-serif; color:#1a1a1a; padding:40px; max-width:800px; margin:0 auto; font-size:13px; }
    .header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:30px; padding-bottom:20px; border-bottom:3px solid #2563EB; }
    .logo { font-size:28px; font-weight:900; color:#2563EB; }
    .logo small { display:block; font-size:11px; color:#666; font-weight:400; }
    .logo-img { width:180px; height:auto; border-radius:10px; margin-bottom:8px; }
    .company-info { text-align:right; font-size:11px; color:#666; line-height:1.6; }
    .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:25px; }
    .info-box { background:#f8f8f8; border-radius:8px; padding:15px; }
    .info-box h4 { font-size:11px; color:#2563EB; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px; }
    .info-box p { font-size:12px; line-height:1.6; color:#333; }
    .info-box strong { color:#1a1a1a; }
    table { width:100%; border-collapse:collapse; margin-bottom:20px; }
    thead th { background:#2563EB; color:white; padding:10px 12px; text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:0.5px; }
    thead th:first-child { border-radius:6px 0 0 0; }
    thead th:last-child { border-radius:0 6px 0 0; }
    tbody td { padding:10px 12px; border-bottom:1px solid #eee; }
    tbody tr:nth-child(even) { background:#fafafa; }
    .text-right { text-align:right; }
    .text-center { text-align:center; }
    .totals { width:300px; margin-left:auto; }
    .totals tr td { padding:8px 12px; }
    .totals tr:last-child { background:#2563EB; color:white; font-weight:bold; font-size:16px; border-radius:6px; }
    .totals tr:last-child td { padding:12px; }
    .notes { background:#f8f8f8; border-radius:8px; padding:15px; margin-top:20px; }
    .notes h4 { font-size:11px; color:#2563EB; text-transform:uppercase; letter-spacing:1px; margin-bottom:5px; }
    .footer { margin-top:40px; padding-top:20px; border-top:1px solid #ddd; display:grid; grid-template-columns:1fr 1fr; gap:40px; }
    .signature { text-align:center; }
    .signature .line { border-top:1px solid #999; margin-top:60px; padding-top:5px; font-size:11px; color:#666; }
    .stamp { text-align:center; font-size:10px; color:#999; margin-top:30px; }
    @media print {
      body { padding:20px; }
      @page { margin:10mm; margin-top:5mm; margin-bottom:5mm; }
      .stamp { display:none; }
    }
    .no-print { text-align:center; margin-bottom:20px; }
    .no-print button { background:#2563EB; color:white; border:none; padding:12px 30px; border-radius:8px; font-size:14px; font-weight:bold; cursor:pointer; margin:0 5px; }
    .no-print button:hover { background:#b91c1c; }
    .no-print button.secondary { background:#666; }
    @media print { .no-print { display:none; } }
  </style>
</head>
<body>
  <div class="no-print">
    <button onclick="window.print()">🖨️ Yazdır / PDF Kaydet</button>
    <button class="secondary" onclick="window.close()">Kapat</button>
  </div>

  <div class="header">
    <div>
      <img src="<%= typeof printLogo!=='undefined' ? printLogo : '/img/ram-logo.jpg' %>" alt="<%= settings.company_name || 'Ram İklimlendirme' %>" class="logo-img">
      <div class="logo"><%= settings.company_name || 'RAM İKLİMLENDİRME' %><small><%= settings.company_subtitle || '' %></small></div>
    </div>
    <div class="company-info">
      <%= settings.owner_name || '' %><br>
      <%= settings.address || '' %><br>
      Tel: <%= settings.phone || '' %><br>
      <%= settings.website || '' %>
    </div>
  </div>

  <div style="text-align:center; margin-bottom:25px;">
    <h1 style="font-size:22px; color:#2563EB; margin-bottom:3px;">TEKLİF FORMU</h1>
    <p style="color:#666; font-size:12px;">Tarih: <%= quote.quote_date %><% if (quote.valid_until) { %> &nbsp;|&nbsp; Geçerlilik: <%= quote.valid_until %><% } %></p>
  </div>

  <div class="info-grid">
    <div class="info-box">
      <h4>Müşteri Bilgileri</h4>
      <p>
        <strong><%= quote.customer_name || '-' %></strong><br>
        <% if (quote.customer_phone) { %>Tel: <%= quote.customer_phone %><br><% } %>
        <% if (quote.customer_address) { %>Adres: <%= quote.customer_address %><% } %>
      </p>
    </div>
    <div class="info-box">
      <h4>Teklif Bilgileri</h4>
      <p>
        <strong>Durum:</strong> <%= quote.status %><br>
        <strong>KDV Oranı:</strong> %<%= quote.tax_rate %><br>
        <% if (quote.discount_value > 0) { %><strong>İndirim:</strong> <%= quote.discount_type==='percent' ? '%'+quote.discount_value : quote.discount_value+' ₺' %><% } %>
      </p>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th style="width:30px">#</th>
        <th>Ürün / Hizmet</th>
        <th>Açıklama</th>
        <th class="text-center" style="width:65px">Miktar</th>
        <th class="text-center" style="width:55px">Birim</th>
        <th class="text-right" style="width:100px">Birim Fiyat</th>
        <th class="text-right" style="width:100px">Toplam</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach((item, i) => { %>
      <tr>
        <td><%= i+1 %></td>
        <td><strong><%= item.product_name %></strong></td>
        <td style="color:#666"><%= item.description || '' %></td>
        <td class="text-center"><%= item.quantity %></td>
        <td class="text-center"><%= item.unit %></td>
        <td class="text-right"><%= Number(item.unit_price).toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</td>
        <td class="text-right"><strong><%= (item.quantity * item.unit_price).toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</strong></td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <table class="totals">
    <tr><td class="text-right" style="color:#666">Ara Toplam:</td><td class="text-right"><%= subtotal.toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</td></tr>
    <% if (discount > 0) { %><tr><td class="text-right" style="color:#666">İndirim:</td><td class="text-right" style="color:#16a34a">-<%= discount.toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</td></tr><% } %>
    <tr><td class="text-right" style="color:#666">KDV (%<%= quote.tax_rate %>):</td><td class="text-right"><%= tax.toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</td></tr>
    <tr><td class="text-right">GENEL TOPLAM</td><td class="text-right"><%= total.toLocaleString('tr-TR', {minimumFractionDigits:2}) %> ₺</td></tr>
  </table>

  <% if (quote.notes) { %>
  <div class="notes">
    <h4>Notlar</h4>
    <p style="font-size:12px; color:#333;"><%= quote.notes %></p>
  </div>
  <% } %>

  <div class="footer">
    <div class="signature">
      <div class="line">Müşteri İmza / Kaşe</div>
    </div>
    <div class="signature">
      <div class="line">Yetkili İmza / Kaşe</div>
    </div>
  </div>

  <div class="stamp">Bu teklif bilgisayar ortamında hazırlanmıştır. — Ram İklimlendirme Satış Takip Sistemi</div>
</body>
</html>
