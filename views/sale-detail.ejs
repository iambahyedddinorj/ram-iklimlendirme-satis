<% const page='sales'; const title='Satış Detayı'; %>
<%- include('layout') %>

<div class="flex flex-wrap gap-3 mb-6">
  <a href="/satis/duzenle/<%= sale.id %>" class="bg-surface border border-border hover:border-red text-muted hover:text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors">
    <span class="material-symbols-outlined text-[18px]">edit</span> Düzenle
  </a>
  <form method="POST" action="/satis/sil" onsubmit="return confirm('Bu satış kaydını silmek istediğinden emin misin?')">
    <input type="hidden" name="id" value="<%= sale.id %>">
    <button class="bg-surface border border-red-900 text-red hover:bg-red-900/30 px-4 py-2 rounded-lg flex items-center gap-2 transition-colors">
      <span class="material-symbols-outlined text-[18px]">delete</span> Sil
    </button>
  </form>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">shopping_bag</span> Satış Bilgileri</h3>
    <div class="space-y-4">
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Ürün</span>
        <span class="font-bold text-lg"><%= sale.product_name %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">İç Ünite Seri No</span>
        <span class="font-mono text-sm bg-bg px-3 py-1 rounded"><%= sale.ic_unite_seri || '-' %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Dış Ünite Seri No</span>
        <span class="font-mono text-sm bg-bg px-3 py-1 rounded"><%= sale.dis_unite_seri || '-' %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Satış Tarihi</span>
        <span><%= sale.sale_date %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Ödeme Şekli</span>
        <span><%= sale.payment_method %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted text-lg">Tutar</span>
        <span class="text-2xl font-bold text-green-400"><%= money(sale.price) %></span>
      </div>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Ödenen</span>
        <span class="font-bold <%= sale.paid_amount >= sale.price ? 'text-green-400' : 'text-yellow-400' %>"><%= money(sale.paid_amount) %></span>
      </div>
      <% if (sale.price - sale.paid_amount > 0) { %>
      <div class="flex justify-between items-center py-3 border-b border-border/30">
        <span class="text-muted">Kalan Borç</span>
        <span class="font-bold text-red text-lg"><%= money(sale.price - sale.paid_amount) %></span>
      </div>
      <% } %>
      <div class="flex justify-between items-center py-3">
        <span class="text-muted">Ödeme Durumu</span>
        <span class="px-3 py-1 rounded-full text-sm font-bold <%= sale.payment_status==='Ödendi'?'bg-green-900/50 text-green-400': sale.payment_status==='Kısmi Ödeme'?'bg-yellow-900/50 text-yellow-400':'bg-red-900/50 text-red-400' %>"><%= sale.payment_status || 'Ödendi' %></span>
      </div>
      <% if (sale.notes) { %>
      <div class="bg-bg rounded-lg p-3 mt-2">
        <span class="text-muted text-sm">Not:</span>
        <p class="mt-1"><%= sale.notes %></p>
      </div>
      <% } %>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">person</span> Müşteri</h3>
    <div class="space-y-3">
      <div class="flex justify-between py-2"><span class="text-muted">Ad Soyad</span><a href="/musteri/<%= sale.customer_id %>" class="text-red hover:underline font-bold"><%= sale.customer_name %></a></div>
      <div class="flex justify-between py-2"><span class="text-muted">Telefon</span><span><%= sale.customer_phone || '-' %></span></div>
      <div class="flex justify-between py-2"><span class="text-muted">Şehir</span><span><%= sale.customer_city || '-' %></span></div>
      <% if (sale.customer_address) { %>
      <div class="flex justify-between py-2"><span class="text-muted">Adres</span><span class="text-right max-w-[60%]"><%= sale.customer_address %></span></div>
      <% } %>
    </div>
    <a href="/musteri/<%= sale.customer_id %>" class="mt-4 inline-block text-red text-sm hover:underline">Tüm satışları gör →</a>
  </div>
</div>

<% if (sale.payment_status !== 'Ödendi') { %>
<div class="mt-6 bg-surface border border-border rounded-xl p-6">
  <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">payments</span> Ödeme Ekle</h3>
  <form method="POST" action="/odeme/kaydet" class="flex flex-wrap gap-3 items-end">
    <input type="hidden" name="sale_id" value="<%= sale.id %>">
    <div class="flex-grow min-w-[140px]">
      <label class="text-muted text-sm block mb-1">Tutar (TL)</label>
      <input name="amount" type="number" step="0.01" required value="<%= (sale.price - sale.paid_amount).toFixed(2) %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
    </div>
    <div class="min-w-[140px]">
      <label class="text-muted text-sm block mb-1">Tarih</label>
      <input name="payment_date" type="date" required value="<%= new Date().toISOString().slice(0,10) %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
    </div>
    <div class="min-w-[120px]">
      <label class="text-muted text-sm block mb-1">Yöntem</label>
      <select name="method" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
        <option>Nakit</option><option>Havale/EFT</option><option>Kredi Kartı</option><option>Çek</option>
      </select>
    </div>
    <div class="flex-grow min-w-[140px]">
      <label class="text-muted text-sm block mb-1">Not</label>
      <input name="note" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Opsiyonel">
    </div>
    <button class="bg-green-700 hover:bg-green-600 text-white font-bold px-6 py-3 rounded-lg">Ödeme Al</button>
  </form>
</div>
<% } %>

<% if (typeof payments !== 'undefined' && payments.length) { %>
<div class="mt-6 bg-surface border border-border rounded-xl p-6">
  <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">history</span> Ödeme Geçmişi</h3>
  <table class="w-full text-left text-sm">
    <thead><tr class="text-muted border-b border-border"><th class="py-2">Tarih</th><th class="py-2">Tutar</th><th class="py-2">Yöntem</th><th class="py-2">Not</th></tr></thead>
    <tbody>
      <% payments.forEach(p => { %>
      <tr class="border-b border-border/30"><td class="py-2"><%= p.payment_date %></td><td class="py-2 text-green-400 font-bold"><%= money(p.amount) %></td><td class="py-2"><%= p.method %></td><td class="py-2 text-muted"><%= p.note || '-' %></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('layout-end') %>
