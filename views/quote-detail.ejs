<%- include('layout') %>

<div class="flex flex-wrap gap-3 mb-6">
  <a href="/teklif/duzenle/<%= quote.id %>" class="bg-surface border border-border hover:border-red text-muted hover:text-white px-4 py-2 rounded-lg flex items-center gap-2">
    <span class="material-symbols-outlined text-[18px]">edit</span> Düzenle
  </a>
  <a href="/teklif/<%= quote.id %>/editor" class="bg-red hover:bg-red-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 font-bold">
    <span class="material-symbols-outlined text-[18px]">edit_document</span> Belge Düzenleyici
  </a>
  <a href="/teklif/<%= quote.id %>/yazdir" target="_blank" class="bg-surface border border-border hover:border-red text-muted hover:text-white px-4 py-2 rounded-lg flex items-center gap-2">
    <span class="material-symbols-outlined text-[18px]">picture_as_pdf</span> PDF İndir
  </a>
  <a href="/teklif/<%= quote.id %>/excel" class="bg-surface border border-border hover:border-green-600 text-muted hover:text-green-400 px-4 py-2 rounded-lg flex items-center gap-2">
    <span class="material-symbols-outlined text-[18px]">table_view</span> Excel İndir
  </a>
  <a href="/teklif/<%= quote.id %>/word" class="bg-surface border border-border hover:border-blue-600 text-muted hover:text-blue-400 px-4 py-2 rounded-lg flex items-center gap-2">
    <span class="material-symbols-outlined text-[18px]">article</span> Word İndir
  </a>
  <form method="POST" action="/teklif/sil" class="inline" onsubmit="return confirm('Bu teklifi silmek istediğinden emin misin?')">
    <input type="hidden" name="id" value="<%= quote.id %>">
    <button class="bg-surface border border-red-900 text-red hover:bg-red-900/30 px-4 py-2 rounded-lg flex items-center gap-2">
      <span class="material-symbols-outlined text-[18px]">delete</span> Sil
    </button>
  </form>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">person</span> Müşteri</h3>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between"><span class="text-muted">Ad Soyad</span><span class="font-bold"><%= quote.customer_name || '-' %></span></div>
      <div class="flex justify-between"><span class="text-muted">Telefon</span><span><%= quote.customer_phone || '-' %></span></div>
      <div class="flex justify-between"><span class="text-muted">Adres</span><span class="text-right max-w-[60%]"><%= quote.customer_address || '-' %></span></div>
    </div>
  </div>
  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">info</span> Teklif Bilgileri</h3>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between"><span class="text-muted">Teklif No</span><span class="font-bold">#<%= quote.id %></span></div>
      <div class="flex justify-between"><span class="text-muted">Tarih</span><span><%= quote.quote_date %></span></div>
      <div class="flex justify-between"><span class="text-muted">Geçerlilik</span><span><%= quote.valid_until || '-' %></span></div>
      <div class="flex justify-between"><span class="text-muted">Durum</span>
        <span class="px-2 py-1 rounded-full text-xs font-bold <%=
          quote.status==='Onaylandı'?'bg-green-900/50 text-green-400':
          quote.status==='Reddedildi'?'bg-red-900/50 text-red-400':
          quote.status==='Gönderildi'?'bg-blue-900/50 text-blue-400':
          'bg-yellow-900/50 text-yellow-400' %>"><%= quote.status %></span>
      </div>
    </div>
  </div>
  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">payments</span> Toplam</h3>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between"><span class="text-muted">Ara Toplam</span><span><%= money(subtotal) %></span></div>
      <% if (discount > 0) { %><div class="flex justify-between"><span class="text-muted">İndirim</span><span class="text-green-400">-<%= money(discount) %></span></div><% } %>
      <div class="flex justify-between"><span class="text-muted">KDV (%<%= quote.tax_rate %>)</span><span><%= money(tax) %></span></div>
      <div class="flex justify-between pt-2 border-t border-border"><span class="text-lg font-bold">TOPLAM</span><span class="text-2xl font-bold text-green-400"><%= money(total) %></span></div>
    </div>
  </div>
</div>

<div class="bg-surface border border-border rounded-xl p-6">
  <h3 class="text-red font-bold mb-4">Kalemler</h3>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead><tr class="text-muted border-b border-border">
        <th class="py-2 pr-3 text-left">#</th>
        <th class="py-2 pr-3 text-left">Ürün / Hizmet</th>
        <th class="py-2 pr-3 text-left">Açıklama</th>
        <th class="py-2 pr-3 text-center">Miktar</th>
        <th class="py-2 pr-3 text-center">Birim</th>
        <th class="py-2 pr-3 text-right">Birim Fiyat</th>
        <th class="py-2 text-right">Toplam</th>
      </tr></thead>
      <tbody>
        <% items.forEach((item, i) => { %>
        <tr class="border-b border-border/30">
          <td class="py-3 pr-3 text-muted"><%= i+1 %></td>
          <td class="py-3 pr-3 font-bold"><%= item.product_name %></td>
          <td class="py-3 pr-3 text-muted"><%= item.description || '-' %></td>
          <td class="py-3 pr-3 text-center"><%= item.quantity %></td>
          <td class="py-3 pr-3 text-center"><%= item.unit %></td>
          <td class="py-3 pr-3 text-right"><%= money(item.unit_price) %></td>
          <td class="py-3 text-right font-bold text-green-400"><%= money(item.quantity * item.unit_price) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (quote.notes) { %>
<div class="bg-surface border border-border rounded-xl p-6 mt-6">
  <h3 class="text-red font-bold mb-2">Notlar</h3>
  <p class="text-muted"><%= quote.notes %></p>
</div>
<% } %>

<%- include('layout-end') %>
