<%- include('layout') %>

<div class="max-w-2xl space-y-6">
  <div class="bg-surface border border-border rounded-xl p-6">
    <h2 class="text-red font-bold text-lg mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">upload_file</span> Excel Dosyasından Teklif Oluştur</h2>
    <p class="text-muted text-sm mb-6">Bir Excel (.xlsx) dosyası yükleyin. Dosyadaki ürünler otomatik olarak okunup yeni bir teklif oluşturulacak. Teklifi oluşturduktan sonra düzenleyebilirsiniz.</p>

    <form method="POST" action="/teklif/excel-import" enctype="multipart/form-data" class="space-y-4">
      <div>
        <label class="text-muted text-sm block mb-1">Excel Dosyası (.xlsx) *</label>
        <input type="file" name="file" accept=".xlsx,.xls" required class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none file:bg-red file:text-white file:border-0 file:rounded file:px-4 file:py-1 file:mr-4 file:cursor-pointer">
      </div>

      <div class="border-t border-border pt-4">
        <h3 class="text-muted text-sm font-bold mb-3">Müşteri Bilgileri (opsiyonel)</h3>
        <div>
          <label class="text-muted text-sm block mb-1">Mevcut Müşteri</label>
          <select id="cust-select" onchange="fillCustomer()" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none mb-3">
            <option value="">— Yeni Müşteri —</option>
            <% customers.forEach(c => { %>
            <option value="<%= c.id %>" data-phone="<%= c.phone || '' %>" data-addr="<%= [c.address, c.city].filter(Boolean).join(', ') %>"><%= c.name %><% if (c.phone) { %> (<%= c.phone %>)<% } %></option>
            <% }) %>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="text-muted text-sm block mb-1">Müşteri Adı</label>
            <input name="customer_name" id="cn" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
          <div>
            <label class="text-muted text-sm block mb-1">Telefon</label>
            <input name="customer_phone" id="cp" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          </div>
        </div>
        <div class="mt-3">
          <label class="text-muted text-sm block mb-1">Adres</label>
          <input name="customer_address" id="ca" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
        </div>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="bg-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg flex items-center gap-2">
          <span class="material-symbols-outlined text-[20px]">upload</span> İçe Aktar ve Teklif Oluştur
        </button>
        <a href="/teklifler" class="bg-surface border border-border text-muted px-6 py-3 rounded-lg hover:text-white flex items-center">İptal</a>
      </div>
    </form>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h3 class="text-red font-bold mb-3 flex items-center gap-2"><span class="material-symbols-outlined">help</span> Excel Formatı</h3>
    <p class="text-muted text-sm mb-3">Uygulama, başlık satırını otomatik algılar. Önerilen sütun sırası:</p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="text-muted border-b border-border">
          <th class="py-2 pr-3 text-left">#</th>
          <th class="py-2 pr-3 text-left">Ürün / Hizmet</th>
          <th class="py-2 pr-3 text-left">Açıklama</th>
          <th class="py-2 pr-3 text-center">Miktar</th>
          <th class="py-2 pr-3 text-center">Birim</th>
          <th class="py-2 text-right">Birim Fiyat</th>
        </tr></thead>
        <tbody>
          <tr class="border-b border-border/30">
            <td class="py-2 pr-3 text-muted">1</td>
            <td class="py-2 pr-3">Klima 12000 BTU</td>
            <td class="py-2 pr-3 text-muted">Split klima</td>
            <td class="py-2 pr-3 text-center">2</td>
            <td class="py-2 pr-3 text-center">Adet</td>
            <td class="py-2 text-right">25000</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function fillCustomer(){
  const sel = document.getElementById('cust-select');
  const opt = sel.options[sel.selectedIndex];
  if(opt.value){
    document.getElementById('cn').value = opt.textContent.split('(')[0].trim();
    document.getElementById('cp').value = opt.dataset.phone;
    document.getElementById('ca').value = opt.dataset.addr;
  }
}
</script>

<%- include('layout-end') %>
