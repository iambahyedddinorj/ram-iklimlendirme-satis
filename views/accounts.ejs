<%- include('layout') %>

<!-- Logolar — istediğin zaman istediğin logoyu yükle -->
<form method="POST" action="/hesaplar/logo" enctype="multipart/form-data" class="bg-surface border border-border rounded-xl p-6 max-w-6xl mb-6">
  <h2 class="text-red font-bold text-lg mb-1 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">image</span> Logolar (Bayi / Servis / Yönetici)</h2>
  <p class="text-muted text-sm mb-5">Her giriş tipi için ayrı logo. Teklif çıktısında, teklifi <strong>kim oluşturduysa</strong> onun logosu görünür. İstediğin zaman değiştirebilirsin — logolar veritabanına kaydedilir, güncellemelerde silinmez. (PNG / JPG önerilir)</p>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
    <% const slots = [['bayi','Bayi Logosu','text-blue-400'],['servis','Servis Logosu','text-green-400'],['admin','Yönetici Logosu','text-yellow-400']]; %>
    <% slots.forEach(([role,label,cls]) => { %>
    <div class="border border-border rounded-lg p-4">
      <label class="block mb-2 font-bold <%= cls %>"><%= label %></label>
      <img src="<%= logoFor(role) %>" class="w-full h-28 object-contain bg-bg border border-border rounded-lg mb-3 p-2">
      <input type="file" name="logo_<%= role %>" accept="image/*" class="block w-full text-xs text-muted file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-red file:text-white file:font-bold file:cursor-pointer">
    </div>
    <% }) %>
  </div>
  <div class="flex flex-wrap gap-3 mt-5">
    <button type="submit" class="bg-red hover:bg-redDark text-white font-bold px-8 py-3 rounded-lg flex items-center gap-2">
      <span class="material-symbols-outlined text-[20px]">upload</span> Seçilen Logoları Yükle
    </button>
    <span class="text-muted text-xs self-center">Sadece değiştirmek istediğin alana dosya seç — boş bıraktıkların aynı kalır.</span>
  </div>
</form>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-6xl">

  <!-- Yeni hesap -->
  <div class="bg-surface border border-border rounded-xl p-6 lg:col-span-1">
    <h2 class="text-red font-bold text-lg mb-2 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">person_add</span> Yeni Hesap</h2>
    <p class="text-muted text-sm mb-4">Bayi, servis veya yönetici hesabı ekle.</p>
    <form method="POST" action="/hesaplar/ekle" class="space-y-3">
      <div>
        <label class="text-muted text-sm block mb-1">Kullanıcı Adı</label>
        <input name="username" required class="w-full bg-bg border border-border rounded-lg px-4 py-2.5 text-white focus:border-red focus:outline-none" placeholder="ör: bayi2">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Görünen Ad</label>
        <input name="name" class="w-full bg-bg border border-border rounded-lg px-4 py-2.5 text-white focus:border-red focus:outline-none" placeholder="ör: Merkez Bayi">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Hesap Tipi</label>
        <select name="role" class="w-full bg-bg border border-border rounded-lg px-4 py-2.5 text-white focus:border-red focus:outline-none">
          <option value="bayi">Bayi</option>
          <option value="servis">Servis</option>
          <option value="admin">Yönetici (Süper Admin)</option>
        </select>
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Şifre</label>
        <input name="password" type="text" required class="w-full bg-bg border border-border rounded-lg px-4 py-2.5 text-white focus:border-red focus:outline-none" placeholder="en az 4 karakter">
      </div>
      <button type="submit" class="w-full bg-red hover:bg-redDark text-white font-bold py-2.5 rounded-lg flex items-center justify-center gap-2"><span class="material-symbols-outlined text-[20px]">add</span> Hesap Ekle</button>
    </form>
  </div>

  <!-- Hesap listesi -->
  <div class="bg-surface border border-border rounded-xl p-6 lg:col-span-2">
    <h2 class="text-red font-bold text-lg mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">groups</span> Hesaplar</h2>
    <div class="space-y-3">
      <% users.forEach(u => { %>
      <div class="border border-border rounded-lg p-4">
        <div class="flex items-center justify-between flex-wrap gap-2">
          <div class="flex items-center gap-3">
            <span class="px-2.5 py-0.5 rounded-full text-[11px] font-bold <%= u.role==='bayi'?'bg-blue-900/50 text-blue-400':u.role==='servis'?'bg-green-900/50 text-green-400':'bg-yellow-900/50 text-yellow-400' %>"><%= roleLabel(u.role) %></span>
            <div>
              <div class="font-bold"><%= u.name %></div>
              <div class="text-muted text-xs">kullanıcı adı: <span class="font-mono"><%= u.username %></span></div>
            </div>
          </div>
          <% if (!(u.id === user.id)) { %>
          <form method="POST" action="/hesaplar/sil" onsubmit="return confirm('<%= u.name %> hesabını silmek istediğine emin misin?')">
            <input type="hidden" name="id" value="<%= u.id %>">
            <button class="text-red/70 hover:text-red flex items-center gap-1 text-sm"><span class="material-symbols-outlined text-[18px]">delete</span> Sil</button>
          </form>
          <% } else { %>
          <span class="text-muted text-xs">(senin hesabın)</span>
          <% } %>
        </div>
        <form method="POST" action="/hesaplar/sifre" class="flex items-end gap-2 mt-3">
          <input type="hidden" name="id" value="<%= u.id %>">
          <div class="flex-grow">
            <label class="text-muted text-xs block mb-1">Yeni şifre belirle</label>
            <input name="new_password" type="text" required class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-white focus:border-red focus:outline-none text-sm" placeholder="yeni şifre">
          </div>
          <button class="bg-surface border border-border hover:border-red text-muted hover:text-white px-4 py-2 rounded-lg text-sm flex items-center gap-1"><span class="material-symbols-outlined text-[18px]">key</span> Değiştir</button>
        </form>
      </div>
      <% }) %>
    </div>
  </div>

</div>

<%- include('layout-end') %>
