<%- include('layout') %>

<form method="POST" action="/ayarlar" class="max-w-2xl space-y-6">
  <div class="bg-surface border border-border rounded-xl p-6">
    <h2 class="text-red font-bold text-lg mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">business</span> Firma Bilgileri</h2>
    <div class="space-y-4">
      <div>
        <label class="text-muted text-sm block mb-1">Firma Adı (Başlık)</label>
        <input name="company_name" value="<%= settings.company_name || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="RAM İKLİMLENDİRME">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Alt Başlık</label>
        <input name="company_subtitle" value="<%= settings.company_subtitle || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="İklimlendirme Sistemleri — Satış, Montaj & Servis">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Firma / İşletme Sahibi</label>
        <input name="owner_name" value="<%= settings.owner_name || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Firma sahibi adı">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-muted text-sm block mb-1">Adres</label>
          <input name="address" value="<%= settings.address || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Adres giriniz">
        </div>
        <div>
          <label class="text-muted text-sm block mb-1">Telefon</label>
          <input name="phone" value="<%= settings.phone || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Telefon giriniz">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-muted text-sm block mb-1">Web Sitesi</label>
          <input name="website" value="<%= settings.website || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Web sitesi giriniz">
        </div>
        <div>
          <label class="text-muted text-sm block mb-1">Vergi No</label>
          <input name="tax_id" value="<%= settings.tax_id || '' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="1234567890">
        </div>
      </div>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h2 class="text-red font-bold text-lg mb-4 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">tune</span> Varsayılan Değerler</h2>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="text-muted text-sm block mb-1">Varsayılan KDV Oranı (%)</label>
        <input name="default_tax_rate" type="number" value="<%= settings.default_tax_rate || '20' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Teklif Geçerlilik Süresi (gün)</label>
        <input name="default_valid_days" type="number" value="<%= settings.default_valid_days || '3' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
      </div>
    </div>
  </div>

  <div class="bg-surface border border-border rounded-xl p-6">
    <h2 class="text-red font-bold text-lg mb-1 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">inventory_2</span> Ürün / Hizmet Listesi</h2>
    <p class="text-muted text-sm mb-4">Teklif oluştururken çıkan öneri listesi. İstediğini ekle, istediğini çıkar.</p>
    <div class="flex gap-2 mb-4">
      <input type="text" id="prod-input" class="flex-grow bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Yeni ürün / hizmet adı" onkeydown="if(event.key==='Enter'){event.preventDefault();addProduct();}">
      <button type="button" onclick="addProduct()" class="bg-red hover:bg-red-700 text-white font-bold px-5 rounded-lg flex items-center gap-1"><span class="material-symbols-outlined text-[20px]">add</span> Ekle</button>
    </div>
    <div id="prod-list" class="flex flex-wrap gap-2"></div>
    <input type="hidden" name="products" id="prod-hidden" value="<%= settings.products || '' %>">
  </div>

  <button type="submit" class="bg-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg flex items-center gap-2">
    <span class="material-symbols-outlined text-[20px]">save</span> Kaydet
  </button>
</form>

<script>
(function(){
  const hidden = document.getElementById('prod-hidden');
  const listEl = document.getElementById('prod-list');
  let products = (hidden.value || '').split('\n').map(s=>s.trim()).filter(Boolean);
  function sync(){ hidden.value = products.join('\n'); render(); }
  function render(){
    listEl.innerHTML = '';
    if(!products.length){ listEl.innerHTML = '<span class="text-muted text-sm">Henüz ürün yok.</span>'; return; }
    products.forEach((p,i)=>{
      const chip = document.createElement('span');
      chip.className = 'inline-flex items-center gap-2 bg-bg border border-border rounded-full pl-4 pr-2 py-2 text-sm';
      chip.innerHTML = '<span></span><button type="button" class="text-muted hover:text-red flex items-center"><span class="material-symbols-outlined text-[18px]">close</span></button>';
      chip.querySelector('span').textContent = p;
      chip.querySelector('button').onclick = ()=>{ products.splice(i,1); sync(); };
      listEl.appendChild(chip);
    });
  }
  window.addProduct = function(){
    const inp = document.getElementById('prod-input');
    const v = inp.value.trim();
    if(v && !products.includes(v)){ products.push(v); inp.value=''; sync(); }
    inp.focus();
  };
  render();
})();
</script>

<form method="POST" action="/ayarlar/sifre" class="max-w-2xl mt-8">
  <div class="bg-surface border border-border rounded-xl p-6 space-y-4">
    <h2 class="text-red font-bold text-lg flex items-center gap-2"><span class="material-symbols-outlined icon-fill">lock</span> Şifre Değiştir</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="text-muted text-sm block mb-1">Yeni Şifre</label>
        <input name="new_password" type="password" required minlength="4" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Yeni Şifre (Tekrar)</label>
        <input name="confirm_password" type="password" required minlength="4" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
      </div>
    </div>
  </div>
  <button type="submit" class="mt-4 bg-red hover:bg-red-700 text-white font-bold w-full py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
    <span class="material-symbols-outlined">key</span> Şifreyi Değiştir
  </button>
</form>

<div class="mt-8 bg-surface border border-border rounded-xl p-6 max-w-2xl">
  <h2 class="text-red font-bold text-lg mb-2 flex items-center gap-2"><span class="material-symbols-outlined icon-fill">info</span> Bilgi</h2>
  <p class="text-muted text-sm">Bu ayarlar tüm teklif çıktılarında (PDF, Excel, Word) kullanılır. Değişiklikler yeni oluşturulan çıktılara yansır.</p>
  <p class="text-muted text-sm mt-2">Şifreyi unutursan: veritabanı dosyası <code class="text-red">~/.ram-iklimlendirme/satis.db</code> içindeki <code class="text-red">users</code> tablosundan sıfırlayabilirsin, ya da bu dosyayı silersen varsayılan şifre (admin123) ile yeniden oluşur.</p>
</div>

<%- include('layout-end') %>
