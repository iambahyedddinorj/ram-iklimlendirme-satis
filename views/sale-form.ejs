<% const page='sales'; const title=sale?'Satış Düzenle':'Yeni Satış'; %>
<%- include('layout') %>

<form method="POST" action="/satis/kaydet" class="max-w-2xl">
  <% if (sale) { %><input type="hidden" name="id" value="<%= sale.id %>"><% } %>

  <div class="bg-surface border border-border rounded-xl p-6 space-y-4">
    <div>
      <label class="text-muted text-sm block mb-1">Müşteri *</label>
      <select name="customer_id" id="customerSelect" required class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
        <option value="">Müşteri seçin...</option>
        <% customers.forEach(c => { %>
          <option value="<%= c.id %>" <%= (sale&&sale.customer_id==c.id)||(preselect==c.id)?'selected':'' %>><%= c.name %> <% if(c.phone){%>(<%=c.phone%>)<%}%></option>
        <% }) %>
      </select>
      <button type="button" onclick="document.getElementById('newCustPanel').classList.toggle('hidden')" class="text-red text-sm hover:underline mt-1 inline-block">+ Yeni müşteri ekle</button>
      <div id="newCustPanel" class="hidden mt-3 bg-bg border border-border rounded-lg p-4 space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <input id="ncName" placeholder="Ad Soyad *" class="bg-surface border border-border rounded-lg px-3 py-2 text-white text-sm focus:border-red focus:outline-none">
          <input id="ncPhone" placeholder="Telefon" class="bg-surface border border-border rounded-lg px-3 py-2 text-white text-sm focus:border-red focus:outline-none">
          <input id="ncCity" placeholder="Şehir" class="bg-surface border border-border rounded-lg px-3 py-2 text-white text-sm focus:border-red focus:outline-none">
        </div>
        <input id="ncAddr" placeholder="Adres" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-white text-sm focus:border-red focus:outline-none">
        <button type="button" onclick="createCustomer()" class="bg-red hover:bg-red-700 text-white text-sm font-bold px-4 py-2 rounded-lg">Müşteri Oluştur</button>
        <span id="ncMsg" class="text-sm ml-2"></span>
      </div>
    </div>

    <div>
      <label class="text-muted text-sm block mb-1">Ürün Adı *</label>
      <input name="product_name" required value="<%= sale?sale.product_name:'' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Örn: Daikin Duvar Tipi 12000 BTU">
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="text-muted text-sm block mb-1">İç Ünite Seri No</label>
        <input name="ic_unite_seri" value="<%= sale?sale.ic_unite_seri||'':'' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white font-mono focus:border-red focus:outline-none" placeholder="HNT-IC-XXXXXXX">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Dış Ünite Seri No</label>
        <input name="dis_unite_seri" value="<%= sale?sale.dis_unite_seri||'':'' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white font-mono focus:border-red focus:outline-none" placeholder="HNT-DIS-XXXXXXX">
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="text-muted text-sm block mb-1">Satış Tarihi *</label>
        <input name="sale_date" type="date" required value="<%= sale?sale.sale_date:new Date().toISOString().slice(0,10) %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Satış Fiyatı (TL) *</label>
        <input name="price" type="number" step="0.01" required value="<%= sale?sale.price:'' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="18500">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Ödeme Şekli</label>
        <select name="payment_method" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          <% ['Nakit','Havale/EFT','Kredi Kartı','Taksit','Çek'].forEach(p => { %>
            <option <%= sale&&sale.payment_method===p?'selected':'' %>><%= p %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="text-muted text-sm block mb-1">Ödenen Tutar (TL)</label>
        <input name="paid_amount" type="number" step="0.01" value="<%= sale?sale.paid_amount:'' %>" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none" placeholder="Boş = tam ödeme">
      </div>
      <div>
        <label class="text-muted text-sm block mb-1">Ödeme Durumu</label>
        <select name="payment_status" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none">
          <% ['Ödendi','Kısmi Ödeme','Ödenmedi'].forEach(s => { %>
            <option <%= sale&&sale.payment_status===s?'selected':'' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div>
      <label class="text-muted text-sm block mb-1">Notlar</label>
      <textarea name="notes" rows="2" class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-white focus:border-red focus:outline-none resize-none" placeholder="Montaj notu, ek bilgi..."><%= sale?sale.notes||'':'' %></textarea>
    </div>
  </div>

  <div class="flex gap-3 mt-4">
    <button type="submit" class="bg-red hover:bg-red-700 text-white font-bold px-8 py-3 rounded-lg transition-colors">
      <%= sale ? 'Güncelle' : 'Kaydet' %>
    </button>
    <a href="<%= sale ? '/satis/'+sale.id : '/satislar' %>" class="bg-surface border border-border text-muted px-6 py-3 rounded-lg hover:text-white transition-colors">İptal</a>
  </div>
</form>

<script>
async function createCustomer(){
  const name=document.getElementById('ncName').value.trim();
  const phone=document.getElementById('ncPhone').value.trim();
  const city=document.getElementById('ncCity').value.trim();
  const address=document.getElementById('ncAddr').value.trim();
  const msg=document.getElementById('ncMsg');
  if(!name){msg.textContent='Ad Soyad gerekli';msg.className='text-sm ml-2 text-red';return;}
  const res=await fetch('/api/musteri/ekle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,phone,city,address})});
  const data=await res.json();
  if(data.id){
    const sel=document.getElementById('customerSelect');
    const opt=new Option(name+(phone?' ('+phone+')':''),data.id,true,true);
    sel.appendChild(opt);
    document.getElementById('newCustPanel').classList.add('hidden');
    document.getElementById('ncName').value='';
    document.getElementById('ncPhone').value='';
    document.getElementById('ncCity').value='';
    document.getElementById('ncAddr').value='';
    msg.textContent='';
  }else{msg.textContent=data.error||'Hata';msg.className='text-sm ml-2 text-red';}
}
</script>
<%- include('layout-end') %>
