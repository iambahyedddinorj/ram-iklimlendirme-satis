<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title!=='undefined'?title:'Satış Takip' %> — Ram İklimlendirme</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL@20..48,100..700,0..1" rel="stylesheet">
  <script>tailwind.config={theme:{extend:{colors:{bg:'#EEF3F9',surface:'#FFFFFF',border:'#D8E1EC',red:'#2563EB',redLight:'#60A5FA',redDark:'#1D4ED8',text:'#0F172A',muted:'#64748B'}}}}</script>
  <style>
    body { background: #EEF3F9; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .icon-fill { font-variation-settings: 'FILL' 1; }
    /* Açık tema: form alanlarında koyu yazı (specificity .text-white'ı geçer) */
    input.text-white, select.text-white, textarea.text-white { color: #0F172A; }
    input::placeholder, textarea::placeholder { color: #94A3B8; }
    .bg-surface, aside { box-shadow: 0 1px 3px rgba(15,23,42,.06); }
    /* Açık tema durum rozetleri */
    .bg-green-900\/50{background:#DCFCE7!important}.text-green-400{color:#15803D!important}
    .bg-red-900\/50{background:#FEE2E2!important}.text-red-400{color:#B91C1C!important}
    .bg-yellow-900\/50{background:#FEF3C7!important}.text-yellow-400{color:#B45309!important}
    .bg-blue-900\/50{background:#DBEAFE!important}.text-blue-400{color:#1D4ED8!important}
    .bg-red-900\/30{background:#FEE2E2!important}.text-red-300{color:#B91C1C!important}.border-red-800{border-color:#FECACA!important}
    .bg-green-900\/30{background:#DCFCE7!important}.text-green-300{color:#15803D!important}.border-green-800{border-color:#BBF7D0!important}
    .bg-red-900\/10{background:#FEF2F2!important}
    .hover\:bg-red-900\/30:hover{background:#FEE2E2!important}
    .hover\:bg-white\/5:hover{background:rgba(15,23,42,.04)!important}
    .hover\:text-white:hover{color:#0F172A!important}
    .border-red-900{border-color:#BFDBFE!important}
  </style>
</head>
<body class="bg-bg text-text min-h-screen flex">
<% if (user) { %>
<% const rc = user.role==='servis' ? {bg:'#16A34A', name:'SERVİS PANELİ'} : user.role==='admin' ? {bg:'#D97706', name:'YÖNETİCİ PANELİ'} : {bg:'#2563EB', name:'BAYİ PANELİ'}; %>
<aside class="hidden md:flex flex-col w-60 bg-surface border-r border-border fixed h-full z-40" style="border-top:5px solid <%= rc.bg %>">
  <div class="px-4 py-4 border-b border-border">
    <img src="<%= logoFor(user.role) %>" alt="<%= settings.company_name || 'Ram İklimlendirme' %>" class="w-full h-auto rounded-xl shadow-sm">
    <p class="text-center text-[11px] text-muted mt-2 tracking-[0.2em] font-semibold">SATIŞ TAKİP</p>
    <div class="mt-3">
      <div class="rounded-lg py-2 text-center text-white text-sm font-extrabold tracking-wide shadow-sm" style="background:<%= rc.bg %>"><%= rc.name %></div>
    </div>
  </div>
  <nav class="flex-grow px-3 py-4 space-y-1">
    <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='dash'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">dashboard</span><span>Ana Sayfa</span>
    </a>
    <a href="/musteriler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='customers'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">group</span><span>Müşteriler</span>
    </a>
    <a href="/satislar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='sales'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">receipt_long</span><span>Satışlar</span>
    </a>
    <a href="/teklifler" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='quotes'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">description</span><span>Teklifler</span>
    </a>
    <a href="/stok" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='stock'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">inventory_2</span><span>Stok</span>
    </a>
    <a href="/kasa" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='kasa'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span><span>Kasa</span>
    </a>
    <a href="/raporlar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='reports'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
      <span class="material-symbols-outlined text-[20px]">bar_chart</span><span>Raporlar</span>
    </a>
    <div class="mt-4 pt-3 border-t border-border/50">
      <% if (user.role==='admin') { %>
      <a href="/hesaplar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='accounts'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
        <span class="material-symbols-outlined text-[20px]">manage_accounts</span><span>Hesaplar</span>
      </a>
      <% } %>
      <a href="/yedek" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='yedek'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
        <span class="material-symbols-outlined text-[20px]">cloud_sync</span><span>Yedekleme</span>
      </a>
      <a href="/ayarlar" class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors <%= typeof page!=='undefined'&&page==='settings'?'bg-red/10 text-red font-bold':'text-muted hover:bg-white/5' %>">
        <span class="material-symbols-outlined text-[20px]">settings</span><span>Ayarlar</span>
      </a>
    </div>
  </nav>
  <div class="px-3 py-4 border-t border-border">
    <a href="/cikis" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-red/70 hover:bg-red/10 transition-colors">
      <span class="material-symbols-outlined text-[20px]">logout</span><span>Çıkış</span>
    </a>
  </div>
</aside>
<div class="flex-grow md:ml-60 min-w-0">
  <header class="bg-bg/80 backdrop-blur border-b border-border sticky top-0 z-30 px-4 sm:px-6 py-4 flex items-center justify-between" style="border-top:4px solid <%= rc.bg %>">
    <div class="flex items-center gap-3 min-w-0">
      <button class="md:hidden text-text" onclick="document.getElementById('mob').classList.toggle('hidden')"><span class="material-symbols-outlined">menu</span></button>
      <h1 class="text-lg sm:text-xl font-bold text-red truncate"><%= typeof title!=='undefined'?title:'' %></h1>
    </div>
    <div class="flex items-center gap-2 sm:gap-3 shrink-0">
      <span class="px-3 py-1 rounded-full text-[11px] sm:text-xs font-extrabold text-white shadow-sm" style="background:<%= rc.bg %>"><%= rc.name %></span>
      <span class="text-muted text-sm hidden sm:inline"><%= user.name %></span>
      <a href="/cikis" class="flex items-center gap-1 text-red hover:opacity-80 font-bold text-sm" title="Çıkış Yap">
        <span class="material-symbols-outlined text-[20px]">logout</span><span class="hidden sm:inline">Çıkış</span>
      </a>
    </div>
  </header>
  <div id="mob" class="md:hidden hidden bg-surface border-b border-border px-3 py-3">
    <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">🏠 Ana Sayfa</a>
    <a href="/musteriler" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">👥 Müşteriler</a>
    <a href="/satislar" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">🧾 Satışlar</a>
    <a href="/teklifler" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">📋 Teklifler</a>
    <a href="/stok" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">📦 Stok</a>
    <a href="/kasa" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">💰 Kasa</a>
    <a href="/raporlar" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">📊 Raporlar</a>
    <% if (user.role==='admin') { %><a href="/hesaplar" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">👤 Hesaplar</a><% } %>
    <a href="/yedek" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">☁️ Yedekleme</a>
    <a href="/ayarlar" class="flex items-center gap-3 px-3 py-2 rounded-lg text-muted">⚙️ Ayarlar</a>
    <a href="/cikis" class="flex items-center gap-3 px-3 py-2 rounded-lg text-red font-bold border-t border-border mt-1 pt-2">🚪 Çıkış Yap</a>
  </div>
  <% if (flash) { %>
  <div class="mx-6 mt-4 px-4 py-3 rounded-lg border <%= flash.type==='error'?'bg-red-900/30 border-red-800 text-redLight':'bg-green-900/30 border-green-800 text-green-300' %>" id="fl">
    <%= flash.msg %>
  </div>
  <script>setTimeout(()=>{var f=document.getElementById('fl');if(f){f.style.transition='opacity .4s';f.style.opacity='0';setTimeout(()=>f.remove(),400);}},3000);</script>
  <% } %>
  <div class="p-6">
<% } %>
